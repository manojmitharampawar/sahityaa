---
import BaseLayout from './BaseLayout.astro';
import { LANGUAGE_NATIVE_NAMES } from '../utils/content-helpers';

interface LanguageInfo {
  code: string;
  name: string;
  nativeName: string;
  isOriginal: boolean;
}

interface Props {
  title: string;
  description?: string;
  lang?: string;
  scriptureTitle?: string;
  scriptureTitleLatin?: string;
  ogType?: string;
  jsonLd?: Record<string, unknown>;
  availableLanguages?: LanguageInfo[];
  translationLanguages?: string[];
}

const {
  title,
  description,
  lang = 'sa',
  scriptureTitle,
  scriptureTitleLatin,
  ogType,
  jsonLd,
  availableLanguages = [],
  translationLanguages = [],
} = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description} lang={lang} ogType={ogType} jsonLd={jsonLd}>
  <div class="reading-toolbar">
    <a href={`${import.meta.env.BASE_URL}`} class="back-link">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><polyline points="12 19 5 12 12 5"/></svg>
      Sahityaa
    </a>
    {scriptureTitleLatin && <span class="toolbar-scripture-name">{scriptureTitleLatin}</span>}
    <div class="toolbar-actions">
      <!-- TOC Button -->
      <button class="toolbar-btn toc-btn" id="toc-toggle" title="Table of Contents" aria-label="Table of Contents">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <button class="toolbar-btn" id="theme-toggle" title="Switch theme" aria-label="Switch theme">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      </button>
      <button class="toolbar-btn" id="font-decrease" title="Decrease font size" aria-label="Decrease font size">A-</button>
      <button class="toolbar-btn" id="font-increase" title="Increase font size" aria-label="Increase font size">A+</button>
      <button class="toolbar-btn" id="read-later-toggle" title="Save for later" aria-label="Toggle read later">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </button>
      <button class="toolbar-btn" id="favorite-toggle" title="Add to favorites" aria-label="Toggle favorite">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </button>
      <button class="toolbar-btn" id="bookmark-toggle" title="Bookmark this page" aria-label="Toggle bookmark">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
      </button>
      <button class="toolbar-btn" id="add-to-list-btn" title="Add to reading list" aria-label="Add to reading list">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
      </button>
      {/* Translation toggle — only if translations exist */}
      {translationLanguages.length > 0 && (
        <div class="translation-toggle-wrap">
          <button class="toolbar-btn translation-toggle-btn" id="translation-toggle" title="Toggle translations" aria-label="Toggle translations">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            <span class="translation-label">Translations</span>
          </button>
          <div class="translation-dropdown" id="translation-dropdown">
            {translationLanguages.map(langCode => (
              <label class="translation-option" data-lang={langCode}>
                <input type="checkbox" checked data-translation-toggle={langCode} />
                <span>{LANGUAGE_NATIVE_NAMES[langCode] || langCode}</span>
              </label>
            ))}
            <div class="translation-dropdown-divider"></div>
            <button class="translation-dropdown-item" id="toggle-all-translations">
              Show/Hide All
            </button>
          </div>
        </div>
      )}
    </div>
  </div>

  <!-- TOC Drawer -->
  <div class="toc-drawer-overlay" id="toc-overlay"></div>
  <div class="toc-drawer" id="toc-drawer">
    <div class="toc-drawer-header">
      <h3>Contents</h3>
      <button class="toc-drawer-close" id="toc-close" aria-label="Close">&times;</button>
    </div>
    <div class="toc-drawer-list" id="toc-list"></div>
  </div>

  <!-- Add to Reading List Modal -->
  <div class="modal-overlay" id="list-modal-overlay">
    <div class="modal">
      <div class="modal-header">
        <h3>Add to Reading List</h3>
        <button class="modal-close" id="list-modal-close" aria-label="Close">&times;</button>
      </div>
      <div class="modal-body">
        <div id="list-modal-lists"></div>
        <div class="modal-create">
          <input type="text" id="new-list-name" placeholder="New list name..." />
          <button class="btn-create" id="create-list-btn">Create</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Toast notification -->
  <div class="toast" id="toast" role="status" aria-live="polite"></div>

  <main class="reading-main">
    <!-- Hidden content source — parsed by BookReader -->
    <div class="reading-content-source" id="content-source" style="display:none;">
      <slot />
    </div>

    <!-- Visible book display -->
    <div class="book-container">
      <div class="book-page-display reading-content" id="book-display" lang={lang}>
        <div class="page-corner-tl"></div>
        <div class="page-corner-br"></div>
      </div>
    </div>

    <!-- Page Navigation -->
    <nav class="page-nav-controls" id="page-nav" aria-label="Page navigation">
      <button class="page-nav-btn" id="prev-page" aria-label="Previous page">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        <span class="nav-label">Prev</span>
      </button>
      <span class="page-indicator" id="page-indicator">Page 1 / 1</span>
      <button class="page-nav-btn" id="next-page" aria-label="Next page">
        <span class="nav-label">Next</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </nav>

    <!-- Page Dots -->
    <div class="page-dots" id="page-dots"></div>
  </main>

  <!-- Progress bar -->
  <div class="reading-progress-pages">
    <div class="bar" id="progress-bar" style="width: 0%"></div>
  </div>
</BaseLayout>

<style is:global>
  @import '../styles/book-flip.css';
</style>

<style>
  @import '../styles/reading.css';

  .toolbar-scripture-name {
    font-size: 0.85em;
    color: var(--color-text-muted);
    font-style: italic;
    display: none;
  }

  @media (min-width: 640px) {
    .toolbar-scripture-name {
      display: inline;
    }
  }

  /* Translation toggle dropdown */
  .translation-toggle-wrap {
    position: relative;
    margin-left: 0.3rem;
    padding-left: 0.55rem;
    border-left: 1px solid var(--color-border-light);
  }

  .translation-toggle-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
  }

  .translation-label {
    font-size: 0.75rem;
    display: none;
  }

  @media (min-width: 640px) {
    .translation-label {
      display: inline;
    }
  }

  .translation-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    box-shadow: 0 4px 16px var(--color-shadow);
    min-width: 180px;
    padding: 0.5rem 0;
    z-index: 200;
    display: none;
  }

  .translation-dropdown.open {
    display: block;
  }

  .translation-option {
    display: flex;
    align-items: center;
    gap: 0.6em;
    padding: 0.5em 1em;
    cursor: pointer;
    font-size: 0.9rem;
    transition: background 0.15s;
  }

  .translation-option:hover {
    background: var(--color-accent-light);
  }

  .translation-option input[type="checkbox"] {
    accent-color: var(--color-accent);
    width: 16px;
    height: 16px;
  }

  .translation-dropdown-divider {
    height: 1px;
    background: var(--color-border-light);
    margin: 0.3rem 0;
  }

  .translation-dropdown-item {
    display: block;
    width: 100%;
    text-align: left;
    padding: 0.5em 1em;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    transition: background 0.15s;
  }

  .translation-dropdown-item:hover {
    background: var(--color-accent-light);
    color: var(--color-accent);
  }

  /* Modal */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 300;
    display: none;
    align-items: center;
    justify-content: center;
  }

  .modal-overlay.open {
    display: flex;
  }

  .modal {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    width: 90%;
    max-width: 400px;
    box-shadow: 0 8px 32px var(--color-shadow);
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.2rem;
    border-bottom: 1px solid var(--color-border-light);
  }

  .modal-header h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
  }

  .modal-close {
    font-size: 1.5rem;
    color: var(--color-text-muted);
    padding: 0 0.3rem;
    line-height: 1;
  }

  .modal-close:hover {
    color: var(--color-text);
  }

  .modal-body {
    padding: 1rem 1.2rem;
  }

  .modal-create {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.8rem;
    padding-top: 0.8rem;
    border-top: 1px solid var(--color-border-light);
  }

  .modal-create input {
    flex: 1;
    padding: 0.5em 0.8em;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 0.9rem;
    background: var(--color-bg);
    color: var(--color-text);
    font-family: inherit;
  }

  .modal-create input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .btn-create {
    padding: 0.5em 1em;
    background: var(--color-btn-primary-bg);
    color: var(--color-btn-primary-text);
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .btn-create:hover {
    opacity: 0.9;
  }

  /* Toast */
  .toast {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: var(--color-text);
    color: var(--color-bg);
    padding: 0.6em 1.2em;
    border-radius: 8px;
    font-size: 0.85rem;
    z-index: 400;
    opacity: 0;
    transition: all 0.3s ease;
    pointer-events: none;
  }

  .toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* Hide content source */
  .reading-content-source {
    display: none !important;
  }

  /* Nav label hidden on very small screens */
  @media (max-width: 400px) {
    .nav-label {
      display: none;
    }
  }
</style>

<script>
  import { prefs, favorites, readLater, bookmarks, progress, readingLists } from '../scripts/storage';
  import type { ThemeMode, FontSize } from '../scripts/storage';
  import { BookReader } from '../scripts/book-reader';

  // ─── Toast helper ───
  function showToast(msg: string) {
    const toast = document.getElementById('toast');
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 2000);
  }

  // ─── Theme toggle ───
  const themeToggle = document.getElementById('theme-toggle');
  const themes: ThemeMode[] = ['sepia', 'light', 'dark'];
  const themeLabels: Record<ThemeMode, string> = { sepia: 'Sepia', light: 'Light', dark: 'Dark' };
  themeToggle?.addEventListener('click', () => {
    const current = prefs.getTheme();
    const idx = themes.indexOf(current);
    const next = themes[(idx + 1) % themes.length];
    document.documentElement.setAttribute('data-theme', next);
    prefs.setTheme(next);
    showToast(`Theme: ${themeLabels[next]}`);
  });

  // ─── Font size controls ───
  const sizes: FontSize[] = ['sm', 'md', 'lg', 'xl'];
  const sizeLabels: Record<FontSize, string> = { sm: 'Small', md: 'Medium', lg: 'Large', xl: 'Extra Large' };
  function getCurrentSizeIdx(): number {
    return Math.max(0, sizes.indexOf(prefs.getFontSize()));
  }
  function setFontSize(idx: number) {
    const clamped = Math.max(0, Math.min(sizes.length - 1, idx));
    sizes.forEach(s => document.documentElement.classList.remove(`font-size-${s}`));
    document.documentElement.classList.add(`font-size-${sizes[clamped]}`);
    prefs.setFontSize(sizes[clamped]);
    showToast(`Font: ${sizeLabels[sizes[clamped]]}`);
  }
  document.getElementById('font-decrease')?.addEventListener('click', () => {
    setFontSize(getCurrentSizeIdx() - 1);
  });
  document.getElementById('font-increase')?.addEventListener('click', () => {
    setFontSize(getCurrentSizeIdx() + 1);
  });

  // ─── Get scripture context ───
  const scriptureEl = document.querySelector<HTMLElement>('[data-scripture-id]');
  const scriptureId = scriptureEl?.dataset.scriptureId || '';
  const pageSlug = window.location.pathname;
  const pageLang = document.documentElement.lang || 'sa';

  function setSvgFill(btn: HTMLElement | null, filled: boolean) {
    btn?.classList.toggle('active', filled);
    btn?.querySelector('svg')?.setAttribute('fill', filled ? 'currentColor' : 'none');
  }

  // ─── Favorite toggle (IndexedDB) ───
  const favoriteBtn = document.getElementById('favorite-toggle');
  async function initFavorite() {
    if (!scriptureId) return;
    const isFav = await favorites.isFavorite(scriptureId);
    setSvgFill(favoriteBtn, isFav);
  }
  favoriteBtn?.addEventListener('click', async () => {
    if (!scriptureId) return;
    const isNowFav = await favorites.toggle(scriptureId);
    setSvgFill(favoriteBtn, isNowFav);
    showToast(isNowFav ? 'Added to favorites' : 'Removed from favorites');
  });
  initFavorite();

  // ─── Read Later toggle (IndexedDB) ───
  const readLaterBtn = document.getElementById('read-later-toggle');
  async function initReadLater() {
    if (!scriptureId) return;
    const inList = await readLater.isInList(scriptureId);
    setSvgFill(readLaterBtn, inList);
  }
  readLaterBtn?.addEventListener('click', async () => {
    if (!scriptureId) return;
    const isNowSaved = await readLater.toggle(scriptureId);
    setSvgFill(readLaterBtn, isNowSaved);
    showToast(isNowSaved ? 'Saved for later' : 'Removed from read later');
  });
  initReadLater();

  // ─── Bookmark toggle (IndexedDB) ───
  const bookmarkBtn = document.getElementById('bookmark-toggle');
  async function initBookmark() {
    const existing = await bookmarks.getForPage(pageSlug);
    setSvgFill(bookmarkBtn, !!existing);
  }
  bookmarkBtn?.addEventListener('click', async () => {
    const currentPageNum = reader?.getCurrentPage() || 0;
    const totalPagesNum = reader?.getTotalPages() || 1;
    const pct = totalPagesNum > 1 ? (currentPageNum / (totalPagesNum - 1)) * 100 : 0;

    const isNowBookmarked = await bookmarks.toggleForPage(pageSlug, {
      scriptureId,
      language: pageLang,
      scrollPercent: pct,
      note: `Page ${currentPageNum + 1}`,
      title: document.title,
    });
    setSvgFill(bookmarkBtn, isNowBookmarked);
    showToast(isNowBookmarked ? `Bookmarked page ${currentPageNum + 1}` : 'Bookmark removed');
  });
  initBookmark();

  // ─── Translation Toggle ───
  const translationToggle = document.getElementById('translation-toggle');
  const translationDropdown = document.getElementById('translation-dropdown');
  const toggleAllBtn = document.getElementById('toggle-all-translations');

  translationToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    translationDropdown?.classList.toggle('open');
  });

  document.addEventListener('click', (e) => {
    if (translationDropdown?.classList.contains('open') && !(e.target as Element)?.closest('.translation-toggle-wrap')) {
      translationDropdown.classList.remove('open');
    }
  });

  // Individual translation toggles
  document.querySelectorAll<HTMLInputElement>('[data-translation-toggle]').forEach(cb => {
    cb.addEventListener('change', () => {
      const lang = cb.dataset.translationToggle!;
      const show = cb.checked;
      // Toggle in interleaved mode
      document.querySelectorAll<HTMLElement>(`[data-translation-lang="${lang}"]`).forEach(el => {
        el.classList.toggle('hidden', !show);
      });
      // Toggle in sequential mode
      document.querySelectorAll<HTMLElement>(`.language-section[data-lang="${lang}"]`).forEach(el => {
        el.classList.toggle('hidden', !show);
      });
      // Re-paginate if book reader is active
      if (reader) {
        reader.rebuild();
      }
    });
  });

  // Toggle all
  toggleAllBtn?.addEventListener('click', () => {
    const checkboxes = document.querySelectorAll<HTMLInputElement>('[data-translation-toggle]');
    const allChecked = Array.from(checkboxes).every(cb => cb.checked);
    checkboxes.forEach(cb => {
      cb.checked = !allChecked;
      cb.dispatchEvent(new Event('change'));
    });
  });

  // ─── Book Reader Initialization ───
  let reader: BookReader | null = null;

  const prevBtn = document.getElementById('prev-page') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-page') as HTMLButtonElement;
  const pageIndicator = document.getElementById('page-indicator');
  const progressBar = document.getElementById('progress-bar');
  const pageDots = document.getElementById('page-dots');

  function updatePageUI(page: number, total: number) {
    if (pageIndicator) {
      pageIndicator.textContent = `Page ${page + 1} / ${total}`;
    }
    if (progressBar) {
      const pct = total > 1 ? ((page + 1) / total) * 100 : 100;
      progressBar.style.width = `${pct}%`;
    }
    if (prevBtn) prevBtn.disabled = page === 0;
    if (nextBtn) nextBtn.disabled = page >= total - 1;
    if (pageDots) {
      const dots = pageDots.querySelectorAll('.page-dot');
      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === page);
      });
    }
    const tocItems = document.querySelectorAll<HTMLElement>('.toc-drawer-item');
    tocItems.forEach(item => {
      const itemPage = parseInt(item.dataset.page || '-1');
      item.classList.toggle('active', itemPage === page);
    });
    debouncedSaveProgress(page, total);
  }

  function buildPageDots(total: number) {
    if (!pageDots) return;
    if (total > 50) {
      pageDots.classList.add('too-many');
      return;
    }
    pageDots.innerHTML = '';
    for (let i = 0; i < total; i++) {
      const dot = document.createElement('button');
      dot.className = 'page-dot' + (i === 0 ? ' active' : '');
      dot.title = `Page ${i + 1}`;
      dot.setAttribute('aria-label', `Go to page ${i + 1}`);
      dot.addEventListener('click', () => reader?.goToPage(i));
      pageDots.appendChild(dot);
    }
  }

  function buildTOC() {
    if (!reader) return;
    const tocList = document.getElementById('toc-list');
    if (!tocList) return;

    const toc = reader.getTableOfContents();
    if (toc.length === 0) {
      tocList.innerHTML = '<p style="padding:1em;color:var(--color-text-muted);font-size:0.9rem;">No sections found</p>';
      return;
    }

    tocList.innerHTML = '';
    for (const item of toc) {
      const btn = document.createElement('button');
      btn.className = 'toc-drawer-item';
      btn.dataset.page = String(item.index);

      const badge = document.createElement('span');
      badge.className = 'toc-page-num';
      badge.textContent = String(item.index + 1);

      const heading = document.createElement('span');
      heading.className = 'toc-heading-text';
      heading.textContent = item.heading;

      btn.appendChild(badge);
      btn.appendChild(heading);

      btn.addEventListener('click', () => {
        reader?.goToPage(item.index);
        closeTOC();
      });
      tocList.appendChild(btn);
    }
  }

  // ─── TOC Drawer ───
  const tocToggle = document.getElementById('toc-toggle');
  const tocDrawer = document.getElementById('toc-drawer');
  const tocOverlay = document.getElementById('toc-overlay');
  const tocClose = document.getElementById('toc-close');

  function openTOC() {
    tocDrawer?.classList.add('open');
    tocOverlay?.classList.add('open');
  }

  function closeTOC() {
    tocDrawer?.classList.remove('open');
    tocOverlay?.classList.remove('open');
  }

  tocToggle?.addEventListener('click', openTOC);
  tocClose?.addEventListener('click', closeTOC);
  tocOverlay?.addEventListener('click', closeTOC);

  // ─── Page nav buttons ───
  prevBtn?.addEventListener('click', () => reader?.prevPage());
  nextBtn?.addEventListener('click', () => reader?.nextPage());

  // ─── Reading Progress (IndexedDB, debounced) ───
  let progressTimer: ReturnType<typeof setTimeout>;
  function debouncedSaveProgress(page: number, total: number) {
    clearTimeout(progressTimer);
    progressTimer = setTimeout(async () => {
      if (!scriptureId) return;
      const pct = total > 1 ? Math.round(((page + 1) / total) * 100) : 100;
      await progress.save({
        scriptureId,
        language: pageLang,
        lastPageSlug: pageSlug,
        currentPage: page,
        totalPages: total,
        scrollPercent: pct,
        percentComplete: pct,
        lastReadAt: Date.now(),
      });
    }, 1500);
  }

  async function tryResumeReading(): Promise<number> {
    if (!scriptureId) return 0;
    const saved = await progress.get(scriptureId, pageLang);
    if (saved && saved.lastPageSlug === pageSlug && saved.currentPage > 0) {
      return saved.currentPage;
    }
    return 0;
  }

  async function initBookReader() {
    reader = new BookReader({
      contentSelector: '#content-source .reading-content',
      pageSelector: '#book-display',
      shlokasPerPage: 3, // Fewer per page since each verse now includes translations
      onPageChange: updatePageUI,
    });

    const ok = reader.init();
    if (!ok) {
      const source = document.getElementById('content-source');
      const display = document.getElementById('book-display');
      if (source && display) {
        display.innerHTML = source.innerHTML;
        source.remove();
      }
      document.getElementById('page-nav')?.remove();
      pageDots?.remove();
      return;
    }

    buildPageDots(reader.getTotalPages());
    buildTOC();

    const resumePage = await tryResumeReading();
    if (resumePage > 0 && resumePage < reader.getTotalPages()) {
      reader.goToPage(resumePage);
      showToast(`Resumed at page ${resumePage + 1}`);
    }
  }

  initBookReader();

  // ─── Add to Reading List modal ───
  const addToListBtn = document.getElementById('add-to-list-btn');
  const listModal = document.getElementById('list-modal-overlay');
  const listModalClose = document.getElementById('list-modal-close');
  const listModalLists = document.getElementById('list-modal-lists');
  const newListInput = document.getElementById('new-list-name') as HTMLInputElement;
  const createListBtn = document.getElementById('create-list-btn');

  async function renderListModal() {
    if (!listModalLists) return;
    const lists = await readingLists.getAll();
    if (lists.length === 0) {
      listModalLists.innerHTML = '<p style="color:var(--color-text-muted);font-size:0.9rem;">No reading lists yet. Create one below.</p>';
      return;
    }
    const listsForThis = await readingLists.getListsForScripture(scriptureId);
    const inListIds = new Set(listsForThis.map(l => l.id));

    listModalLists.innerHTML = lists.map(l => `
      <label class="list-option" style="display:flex;align-items:center;gap:0.6em;padding:0.5em 0;cursor:pointer;font-size:0.9rem;">
        <input type="checkbox" data-list-id="${l.id}" ${inListIds.has(l.id) ? 'checked' : ''} style="accent-color:var(--color-accent);width:16px;height:16px;" />
        <span>${l.name}</span>
        <span style="margin-left:auto;font-size:0.75rem;color:var(--color-text-muted);">${l.items.length} items</span>
      </label>
    `).join('');

    listModalLists.querySelectorAll('input[type="checkbox"]').forEach(cb => {
      cb.addEventListener('change', async (e) => {
        const input = e.target as HTMLInputElement;
        const listId = input.dataset.listId!;
        if (input.checked) {
          await readingLists.addItem(listId, scriptureId);
          showToast('Added to list');
        } else {
          await readingLists.removeItem(listId, scriptureId);
          showToast('Removed from list');
        }
      });
    });
  }

  addToListBtn?.addEventListener('click', async () => {
    await renderListModal();
    listModal?.classList.add('open');
  });

  listModalClose?.addEventListener('click', () => {
    listModal?.classList.remove('open');
  });

  listModal?.addEventListener('click', (e) => {
    if (e.target === listModal) listModal.classList.remove('open');
  });

  createListBtn?.addEventListener('click', async () => {
    const name = newListInput?.value.trim();
    if (!name) return;
    await readingLists.create(name);
    if (newListInput) newListInput.value = '';
    await renderListModal();
    showToast(`List "${name}" created`);
  });

  newListInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') createListBtn?.click();
  });
</script>
