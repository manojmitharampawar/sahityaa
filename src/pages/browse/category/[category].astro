---
import BrowseLayout from '../../../layouts/BrowseLayout.astro';
import TextCard from '../../../components/cards/TextCard.astro';
import Breadcrumbs from '../../../components/common/Breadcrumbs.astro';
import { getScriptureIndex } from '../../../utils/content-helpers';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = await getCollection('categories');
  return categories.map(cat => ({
    params: { category: cat.id },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const scriptures = await getScriptureIndex();
const filtered = scriptures.filter(s => s.category === category.id);
const base = import.meta.env.BASE_URL;
---

<BrowseLayout title={category.data.nameLatin} description={category.data.description}>
  <Breadcrumbs items={[
    { label: 'Home', href: base },
    { label: 'Browse', href: `${base}browse/` },
    { label: category.data.nameLatin },
  ]} />

  <header class="page-header">
    <h1 class="page-title">
      <span class="title-native">{category.data.name}</span>
      <span class="title-latin">{category.data.nameLatin}</span>
    </h1>
    {category.data.description && <p class="page-description">{category.data.description}</p>}
    <p class="result-count">{filtered.length} text{filtered.length !== 1 ? 's' : ''}</p>
  </header>

  <div class="texts-grid">
    {filtered.map(s => (
      <TextCard
        id={s.id}
        firstTextId={s.firstTextId}
        titleLatin={s.titleLatin}
        titles={s.titles}
        category={s.category}
        author={s.author}
        languages={s.languages}
        description={s.description}
        panth={s.panth}
        hasChapters={s.hasChapters}
        totalChapters={s.totalChapters}
        langUrls={s.langUrls}
      />
    ))}
  </div>

  {filtered.length === 0 && (
    <p class="empty-state">No texts available in this category yet. More content coming soon.</p>
  )}
</BrowseLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-title {
    display: flex;
    align-items: baseline;
    gap: 0.5em;
    flex-wrap: wrap;
  }

  .title-native {
    font-family: var(--font-reading);
    font-size: 2rem;
    font-weight: 700;
  }

  .title-latin {
    font-size: 1.3rem;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .page-description {
    color: var(--color-text-secondary);
    margin-top: 0.5rem;
    max-width: 600px;
    line-height: 1.6;
  }

  .result-count {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }

  .texts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.2rem;
  }

  .empty-state {
    text-align: center;
    color: var(--color-text-muted);
    padding: 3rem;
    font-style: italic;
  }

  @media (max-width: 640px) {
    .texts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
